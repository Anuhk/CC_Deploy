# ─────────────────────────────────────────────────────
# Student Portal — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# JWT Secret — change this to a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─────────────────────────────────────────────────────
# SUPABASE — Get these from https://supabase.com/dashboard
# Project Settings → API
# ─────────────────────────────────────────────────────

# Your Supabase project URL (e.g. https://xyzxyzxyz.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe for frontend)
SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key (server-side ONLY — never expose to frontend!)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# PostgreSQL connection string — from Supabase dashboard:
# Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres
